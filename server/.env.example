NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/homeos
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:8081
LOG_LEVEL=debug
# Optional — Firebase Admin SDK service account, as a single-line JSON string.
# Push notifications are a no-op until this is set (see src/services/pushService.ts).
FIREBASE_SERVICE_ACCOUNT=
# Optional — Google Gemini API key (https://aistudio.google.com/apikey).
# Photo-based product identification is a no-op until this is set
# (see src/services/productPhotoService.ts).
GEMINI_API_KEY=
